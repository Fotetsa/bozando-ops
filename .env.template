# Copier en .env et renseigner. Ne jamais committer .env.

# --- Postgres ---
POSTGRES_USER=ops
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=bozando_ops
DATABASE_URL=postgresql://ops:change-me-strong@localhost/bozando_ops

# --- Redis (dev local ; en compose c'est redis://redis:6379) ---
REDIS_URL=redis://localhost:6379

# --- Auth (CLÉS MAÎTRESSES — générer avec: openssl rand -hex 32) ---
# Secret de signature JWT. Ne JAMAIS changer après émission de tokens.
JWT_SECRET=change-me-64-hex
# Clé maîtresse de chiffrement de TOUS les secrets (MFA TOTP, clés SSH-outil,
# tokens registre). STABLE en prod : la changer rend tout indéchiffrable. SAUVEGARDE.
MFA_ENCRYPTION_KEY=change-me-64-hex

# --- API (back) ---
API_HOST=127.0.0.1
API_PORT=4000
WEB_ORIGIN=http://localhost:5273

# --- URL publique (Caddy / CORS) ---
# En prod via install.sh : https://<domaine>. PUBLIC_HOST active HTTPS auto Caddy.
PUBLIC_URL=http://localhost:5273
# PUBLIC_HOST=ops.exemple.com

# --- Docker ---
# PROD : pilotage via le docker-socket-proxy (API Docker filtrée, EXEC bloqué).
# DOCKER_HOST=tcp://socket-proxy:2375
# DEV : socket Unix local (utilisé si DOCKER_HOST absent).
# DOCKER_SOCKET_PATH=/var/run/docker.sock

# --- Caddy (exposition dynamique des passerelles) ---
# DEV: http://localhost:2019 ; en compose: http://caddy:2019
# CADDY_ADMIN_URL=http://localhost:2019

# --- Images GHCR (compose de prod) ---
# GHCR_OWNER=bright77777
# IMAGE_TAG=latest

# --- Jobs (intervalles, optionnel) ---
# DRIFT_INTERVAL_MS=60000
# AUTOSCALE_INTERVAL_MS=30000
# AUTOSCALE_COOLDOWN_MS=90000
